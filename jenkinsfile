pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:18-alpine'
                    reuseNode true
                }
            }
            steps {
                sh '''
                   ls -la
                   node --version
                   npm --version
                   npm ci 
                   npm run build 
                   ls -la
                '''
            }
        }

        stage('Tests') {
            parallel {
                stage('Unit tests') {
                    agent {
                        docker {
                            image 'node:18-alpine'
                            reuseNode true
                        }
                    }
                    steps {
                        sh '''
                          npm ci
                          test -f build/index.html || { echo "❌ Build missing!"; exit 1; }
                          CI=true npm test
                        '''
                    }
                }
                stage('E2E') {
                    agent {
                        docker {
                            image 'mcr.microsoft.com/playwright:v1.59.1-noble'
                            reuseNode false
                        }
                    }
                    steps {
                        sh '''
                            npm ci
                            npm install -g serve

                            # Vérifier que le build existe
                            test -f build/index.html || { echo "❌ Build missing!"; exit 1; }

                            # Démarrer le serveur
                            npx serve -s build -l 3000 &
                            SERVER_PID=$!

                            # Attendre que le serveur soit vraiment prêt
                            echo "Waiting for server..."
                            for i in {1..30}; do
                              STATUS=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:3000)
                              if [ "$STATUS" -eq 200 ]; then
                                echo "Server ready ✅"
                                break
                              fi
                              sleep 1
                            done

                            # Lancer les tests Playwright
                            npx playwright test --reporter=html

                            # Arrêter le serveur
                            kill $SERVER_PID
                        '''
                    }
                }
            }
        }

        stage('Install') {
            agent {
               docker {
                   image 'node:18-alpine'
                   reuseNode true
               }
            }
            steps {
              sh 'npm ci'
            }
        }
    }

    post {
        always {
            junit 'jest-results/junit.xml'
            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: false,
                icon: '',
                keepAll: false,
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: 'Playwright HTML Report',
                reportTitles: '',
                useWrapperFileDirectly: true
            ])
        }
    }
}